{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "staging/YYYY-MM-DD.json",
  "description": "Raw daily scrape output from the Claude routine. A flat array of article candidates, before deduplication against articles.json.",
  "type": "array",
  "minItems": 1,
  "items": { "$ref": "#/$defs/article" },
  "$defs": {
    "article": {
      "type": "object",
      "required": ["id", "title", "vendor", "source", "url", "date", "description", "score", "scraped_at"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$",
          "description": "sha256(url)[:16]"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "vendor": {
          "type": "string",
          "enum": ["Anthropic", "OpenAI", "Google", "xAI", "Cursor", "Microsoft", "Apple", "Meta", "Industry"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "scraped_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    }
  }
}
